# Database
DATABASE_URL="postgresql://usuario:senha@localhost:5432/autswot?schema=public"

# JWT
JWT_SECRET="sua-chave-secreta-super-segura-mude-isso"
JWT_REFRESH_SECRET="sua-chave-refresh-secreta-super-segura-mude-isso"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV="development"

# CORS — em produção, lista separada por vírgula
# Desenvolvimento:
FRONTEND_URL="http://localhost:5173,http://localhost:5174"
# Produção (definir no docker-compose.yml ou na env da VPS):
# FRONTEND_URL="https://app.autswot.com,https://admin.autswot.com"
