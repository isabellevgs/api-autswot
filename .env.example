SERVICE_FQDN_API=
SERVICE_URL_API=
# CORS — origens permitidas (vírgula)
# Desenvolvimento local:
FRONTEND_URL=http://localhost:5173,http://localhost:5174
# Produção (Coolify): defina exatamente isto nas variáveis de ambiente do serviço api-autswot
# FRONTEND_URL=https://app.autswot.com,https://painel.autswot.com
JWT_EXPIRES_IN=
JWT_REFRESH_EXPIRES_IN=
JWT_REFRESH_SECRET=
JWT_SECRET=
NODE_ENV=
POSTGRES_PASSWORD=
# Construída automaticamente pelo docker-compose a partir de POSTGRES_PASSWORD
# Deve ser definida explicitamente no Coolify caso a interpolação não funcione
DATABASE_URL=postgresql://autswot_user:POSTGRES_PASSWORD@postgres:5432/autswot?schema=public
PORT=3000