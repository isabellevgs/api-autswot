{
  "name": "api-autswot",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "test": "bun test",
    "test:unit": "bun test src/tests/unit",
    "test:integration": "bun test src/tests/integration",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "studio": "bun x prisma studio",
    "migrate": "bun x prisma migrate dev",
    "generate": "bun x prisma generate",
    "migrate:deploy": "bun x prisma migrate deploy",
    "db:push": "bun x prisma db push",
    "db:seed": "bun run prisma/seed.ts"
  },
  "private": true,
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "pino-pretty": "^12.0.0",
    "prisma": "^7.0.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "@prisma/client": "^7.0.1",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.6.1",
    "zod": "^4.1.12"
  }
}
